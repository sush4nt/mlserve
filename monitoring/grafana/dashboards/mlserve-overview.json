{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "title": "MLServe Overview",
  "uid": "mlserve-overview",
  "tags": ["mlserve"],
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests per Second — by Model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(rest_server_requests_total{endpoint=~\".*/infer\"}[1m])",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Avazu Inference Latency Percentiles (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(rest_server_request_duration_seconds_bucket{endpoint=~\".*avazu.*infer\"}[5m])))",
          "legendFormat": "{{endpoint}} p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(rest_server_request_duration_seconds_bucket{endpoint=~\".*avazu.*infer\"}[5m])))",
          "legendFormat": "{{endpoint}} p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(rest_server_request_duration_seconds_bucket{endpoint=~\".*avazu.*infer\"}[5m])))",
          "legendFormat": "{{endpoint}} p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Concurrent Requests In Flight",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rest_server_requests_in_progress{endpoint=~\".*/infer\"}",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Rate (non-200 / total)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rest_server_requests_total{status_code!=\"200\", endpoint=~\".*/infer\"}[1m])) / clamp_min(sum(rate(rest_server_requests_total{endpoint=~\".*/infer\"}[1m])), 1)",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Predictions Served",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rest_server_requests_total{endpoint=~\".*/infer\", status_code=\"200\"})",
          "legendFormat": "served"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "NYC Taxi — p95 Inference Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rest_server_request_duration_seconds_bucket{endpoint=~\".*nyc-taxi.*infer\"}[5m])))",
          "legendFormat": "taxi p95"
        }
      ]
    }
  ]
}
